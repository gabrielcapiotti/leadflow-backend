# ========================================
# LeadFlow Backend - Environment Configuration
# ========================================
# Copy this file to .env and fill in real values
# DO NOT commit .env to version control!

# ========================================
# Server Configuration
# ========================================
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,prometheus,metrics

# ========================================
# Spring Boot Configuration
# ========================================
SPRING_PROFILES_ACTIVE=prod
SPRING_APPLICATION_NAME=leadflow-backend
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/leadflow_prod
SPRING_DATASOURCE_USERNAME=leadflow_user
SPRING_DATASOURCE_PASSWORD=SECURE_PASSWORD_HERE
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=20000

# ========================================
# Flyway Database Migration
# ========================================
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
SPRING_FLYWAY_OUT_OF_ORDER=false

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_here
JWT_EXPIRATION_MS=86400000

# ========================================
# Stripe Payment Configuration
# ========================================
STRIPE_API_KEY=sk_live_YOUR_LIVE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_live_YOUR_WEBHOOK_SECRET_HERE
STRIPE_CURRENCY=USD
STRIPE_TIMEOUT_SECONDS=30

# ========================================
# Email Configuration (SMTP)
# ========================================
# Option A: Gmail SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_FROM=noreply@leadflow.com

# Option B: SendGrid SMTP (commented out)
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.YOUR_SENDGRID_API_KEY_HERE
# MAIL_FROM=noreply@leadflow.com

# Option C: AWS SES SMTP (commented out)
# MAIL_HOST=email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=YOUR_AWS_SES_USERNAME
# MAIL_PASSWORD=YOUR_AWS_SES_PASSWORD
# MAIL_FROM=noreply@leadflow.com

MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_CONNECTIONTIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITETIMEOUT=5000

# ========================================
# Email Notification Configuration
# ========================================
EMAIL_TEMPLATES_PATH=classpath:templates/
EMAIL_CONFIRMATION_SUBJECT=Subscription Confirmed - LeadFlow
EMAIL_FAILURE_SUBJECT=Payment Failed - LeadFlow
EMAIL_INVOICE_SUBJECT=Invoice ${invoice_number} - LeadFlow
EMAIL_SUPPORT_EMAIL=support@leadflow.com

# ========================================
# Webhook Configuration
# ========================================
WEBHOOK_ENABLED=true
WEBHOOK_MAX_RETRIES=3
WEBHOOK_INITIAL_DELAY_MS=1000
WEBHOOK_MAX_DELAY_MS=30000
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_SIGNATURE_VALIDATION_ENABLED=true
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# ========================================
# Logging Configuration
# ========================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_LEADFLOW=DEBUG
LOGGING_LEVEL_COM_LEADFLOW_WEBHOOK=INFO
LOGGING_LEVEL_SQLDiag=WARN
LOGGING_FILE_NAME=logs/leadflow.log
LOGGING_FILE_MAX_SIZE=10MB
LOGGING_FILE_MAX_HISTORY=30

# ========================================
# Metrics & Monitoring
# ========================================
MANAGEMENT_METRICS_ENABLE_JVM=true
MANAGEMENT_METRICS_ENABLE_PROCESS=true
MANAGEMENT_METRICS_ENABLE_SYSTEM=true
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,prometheus,metrics

# ========================================
# Sentry (Error Tracking) - Optional
# ========================================
SENTRY_ENABLED=false
SENTRY_DSN=https://YOUR_SENTRY_KEY@sentry.io/YOUR_PROJECT_ID
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ========================================
# Multi-Tenant Configuration
# ========================================
MULTITENANCY_ENABLED=true
MULTITENANCY_TENANT_ID_HEADER=X-Tenant-ID
MULTITENANCY_ISOLATION_STRICT=true

# ========================================
# Security Configuration
# ========================================
SECURITY_CORS_ALLOWED_ORIGINS=https://app.leadflow.com,https://dashboard.leadflow.com
SECURITY_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
SECURITY_CORS_MAX_AGE=3600
SECURITY_REQUIRE_HTTPS=true
SECURITY_HSTS_MAX_AGE=31536000

# ========================================
# Circuit Breaker Configuration (Resilience4j)
# ========================================
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_STRIPE_FAILURE_RATE_THRESHOLD=50
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_STRIPE_MINIMUM_NUMBER_OF_CALLS=10
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_STRIPE_AUTOMATIC_TRANSITION_FROM_OPEN_TO_HALF_OPEN_ENABLED=true
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_STRIPE_WAIT_DURATION_IN_OPEN_STATE=60000

# ========================================
# Application-Specific Configuration
# ========================================
APP_NAME=LeadFlow
APP_VERSION=1.0.0
APP_ENVIRONMENT=production
APP_DEBUG_MODE=false

# ========================================
# Development Configuration Flags
# ========================================
# Set to false in production
DEV_MOCK_STRIPE_RESPONSES=false
DEV_SKIP_WEBHOOK_SIGNATURE_VALIDATION=false
DEV_SMTP_USE_MAILDEV=false
DEV_DATABASE_RESET_ON_STARTUP=false
